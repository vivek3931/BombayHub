{
  "name": "bombay-hub-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend && mv frontend/.next ./.next && cp -r frontend/public ./public",
    "start": "npm run start --workspace=frontend"
  },
  "devDependencies": {
    "next": "16.1.1"
  }
}
